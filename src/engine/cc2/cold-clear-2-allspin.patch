+++ b/src/api.rs
@@ -0,0 +1,105 @@
+// wasm-bindgen wrapper: drive the Cold Clear 2 bot single-threaded from JS.
+// Bypasses the threaded BotSyncronizer/TBP harness - we build one bot per
+// query, think for a fixed number of work units, and read back the best move.
+
+use std::sync::Arc;
+
+use enumset::EnumSet;
+use wasm_bindgen::prelude::*;
+
+use crate::bot::{Bot, BotConfig, BotOptions};
+use crate::data::{Board, GameState, Piece, Placement};
+
+fn to_piece(c: char) -> Option<Piece> {
+    Some(match c {
+        'I' => Piece::I, 'O' => Piece::O, 'T' => Piece::T,
+        'L' => Piece::L, 'J' => Piece::J, 'S' => Piece::S, 'Z' => Piece::Z,
+        _ => return None,
+    })
+}
+fn piece_char(p: Piece) -> char {
+    match p { Piece::I=>'I', Piece::O=>'O', Piece::T=>'T', Piece::L=>'L', Piece::J=>'J', Piece::S=>'S', Piece::Z=>'Z' }
+}
+fn spin_char(s: crate::data::Spin) -> char {
+    match s { crate::data::Spin::None=>'n', crate::data::Spin::Mini=>'m', crate::data::Spin::Full=>'f' }
+}
+
+#[wasm_bindgen]
+pub struct ColdClear {
+    bot: Bot,
+    board: Board,
+    active: Piece,
+}
+
+#[wasm_bindgen]
+impl ColdClear {
+    /// `cols`: 10 column bitboards (bit y set => filled at row y, y up).
+    /// `queue`: upcoming pieces as letters, front = current piece.
+    /// `hold`: single hold-piece letter, or "" for empty.
+    /// `weights`: a `BotConfig` JSON string to override the default evaluation
+    /// (e.g. an LST-loop profile), or "" to use the built-in defaults.
+    #[wasm_bindgen(constructor)]
+    pub fn new(cols: &[u32], queue: &str, hold: &str, back_to_back: bool, combo: u8, weights: &str) -> Result<ColdClear, JsValue> {
+        let mut board = Board::default();
+        for x in 0..10usize.min(cols.len()) { board.cols[x] = cols[x] as u64; }
+        let mut q: Vec<Piece> = queue.chars().filter_map(to_piece).collect();
+        if q.is_empty() { return Err(JsValue::from_str("empty queue")); }
+        let active = q[0];
+        // mirror tbp create_bot: reserve = hold, else the first queued piece
+        let reserve = match hold.chars().next().and_then(to_piece) {
+            Some(h) => h,
+            None => q.remove(0),
+        };
+        let state = GameState { board, bag: EnumSet::all(), reserve, back_to_back, combo };
+        let config = if weights.is_empty() {
+            BotConfig::default()
+        } else {
+            serde_json::from_str(weights)
+                .map_err(|e| JsValue::from_str(&format!("bad weights JSON: {e}")))?
+        };
+        let bot = Bot::new(BotOptions { speculate: false, config: Arc::new(config) }, state, &q);
+        Ok(ColdClear { bot, board, active })
+    }
+
+    /// Run `iters` units of search work (grows the tree).
+    pub fn work(&self, iters: u32) {
+        for _ in 0..iters { self.bot.do_work(); }
+    }
+
+    /// Ranked moves (best first) as a JSON array, or null if none. Each item:
+    /// piece, spin ('n'|'m'|'f'), lines, usesHold, soft (needs a soft-drop /
+    /// tuck - a more cognitively demanding placement), cells (8 ints), x, y.
+    pub fn suggest(&self) -> Option<String> {
+        let moves = self.bot.suggest();
+        if moves.is_empty() {
+            return None;
+        }
+        let items: Vec<String> = moves
+            .into_iter()
+            .take(18)
+            .map(|mv| {
+                let loc = mv.location;
+                let cells = loc.cells();
+                let mut b = self.board;
+                b.place(loc);
+                let lines = b.line_clears().count_ones();
+                // reachable by a pure hard drop? straight-drop from above the
+                // stack must land exactly at the final row.
+                let mut top = loc;
+                top.y = 32;
+                while top.obstructed(&self.board) && top.y < 40 {
+                    top.y += 1;
+                }
+                let landing = top.y - top.drop_distance(&self.board);
+                let soft = landing != loc.y;
+                let cell_json: Vec<i8> = cells.iter().flat_map(|&(x, y)| [x, y]).collect();
+                format!(
+                    "{{\"piece\":\"{}\",\"spin\":\"{}\",\"lines\":{},\"usesHold\":{},\"soft\":{},\"x\":{},\"y\":{},\"cells\":{:?}}}",
+                    piece_char(loc.piece), spin_char(mv.spin), lines,
+                    loc.piece != self.active, soft, loc.x, loc.y, cell_json,
+                )
+            })
+            .collect();
+        Some(format!("[{}]", items.join(",")))
+    }
+}
