{
  "name": "tetr-ai",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "app": "vite build && electron .",
    "app:dev": "ELECTRON_START_URL=http://localhost:5199 electron .",
    "dev": "vite",
