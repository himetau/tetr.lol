    "gen:fourwide-db": "tsx tools/gen-fourwide-db.ts"
  },
  "dependencies": {
    "tetris-fumen": "^1.1.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "playwright": "^1.61.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
